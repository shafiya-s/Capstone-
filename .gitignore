# ==============================
# FreshTrack AI - .gitignore
# ==============================

# ── Python Backend ────────────
backend/.venv/
backend/__pycache__/
backend/app/__pycache__/
backend/**/__pycache__/
backend/*.pyc
backend/*.pyo
backend/*.pyd
backend/.Python
backend/*.egg-info/
backend/dist/
backend/build/
backend/.eggs/

# Database (don't commit the db; users create their own)
backend/kitchen.db

# Python environment
*.env
.env.local
.env.production

# ── Node / Frontend ───────────
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/

# Vite cache
frontend/.cache/

# ── IDE / Editor ──────────────
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
.DS_Store
Thumbs.db

# ── OS ────────────────────────
Desktop.ini
$RECYCLE.BIN/

# ── Logs ─────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Misc ─────────────────────
*.tmp
*.temp
